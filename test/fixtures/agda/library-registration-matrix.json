[
  {
    "name": "broken-global-defaults-with-project-library",
    "projectFiles": [
      {
        "path": "project.agda-lib",
        "contents": "name: project\ninclude: lib\n"
      },
      {
        "path": "lib/Dep.agda",
        "contents": "module Dep where\n\nopen import Agda.Builtin.Nat\n\nx : Nat\nx = 0\n"
      },
      {
        "path": "lib/Main.agda",
        "contents": "module Main where\n\nopen import Agda.Builtin.Nat\nopen import Dep\n\nanswer : Nat\nanswer = x\n"
      }
    ],
    "agdaDirFiles": [
      {
        "path": "standard-library.agda-lib",
        "contents": "name: standard-library\ninclude: src\n"
      },
      {
        "path": "libraries",
        "contents": "standard-library.agda-lib\nmissing.agda-lib\n"
      },
      {
        "path": "defaults",
        "contents": "standard-library\nmissing\n"
      }
    ],
    "expectedAgdaArgs": ["-l", "project"],
    "expectedLibraryBasenames": ["standard-library.agda-lib", "project.agda-lib"],
    "expectedDefaults": ["standard-library"],
    "integration": {
      "loadFile": "lib/Main.agda"
    }
  },
