# Normalize line endings
* text=auto eol=lf

# Source files
*.ts        text eol=lf linguist-language=TypeScript
*.mjs       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf
*.agda      text eol=lf
*.agda-lib  text eol=lf
*.lagda     text eol=lf
*.lagda.md  text eol=lf

# Binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.pdf  binary
